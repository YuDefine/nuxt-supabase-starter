{
  "name": "nuxt-supabase-starter",
  "version": "0.31.0",
  "private": true,
  "author": "YuDefine - 域定資訊工作室 (https://github.com/YuDefine)",
  "repository": {
    "type": "git",
    "url": "https://github.com/YuDefine/nuxt-supabase-starter.git"
  },
  "type": "module",
  "scripts": {
    "audit:ux-drift": "node scripts/audit-ux-drift.mts",
    "build": "nuxt build",
    "check": "pnpm check:vue-components && vp check && pnpm typecheck",
    "check:vue-components": "npx tsx scripts/check-vue-component-resolution.mts",
    "db:backup": "bash ./scripts/backup-supabase.sh",
    "db:diff": "supabase db diff",
    "db:drizzle:pull": "drizzle-kit pull --config=drizzle.config.ts",
    "db:drizzle:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:lint": "bash ./scripts/db-lint.sh",
    "db:reset": "bash ./scripts/db-reset.sh",
    "db:types": "bash ./scripts/db-types.sh",
    "dev": "nuxt dev --dotenv .env -o",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs --open",
    "docs:preview": "vitepress preview docs",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "hub:bootstrap": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/bootstrap-hub.mjs",
    "hub:check": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/sync-rules.mjs --check",
    "hub:doctor": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/sync-rules.mjs --check",
    "hub:prune": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/sync-rules.mjs --prune",
    "hub:sync": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/hub-sync.mjs",
    "hub:vendor": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/sync-vendor.mjs",
    "hub:vendor:check": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/sync-vendor.mjs --check",
    "hub:vendor:force": "node ${CLADE_HOME:-$HOME/offline/clade}/scripts/sync-vendor.mjs --force",
    "lint": "vp lint --deny-warnings",
    "postgrest:ready": "node scripts/postgrest-ready-gate.mjs",
    "postgrest:risk": "node scripts/postgrest-migration-risk.mjs",
    "postgrest:smoke": "node scripts/postgrest-smoke.mjs",
    "postinstall": "node -e \"const f=require('node:fs'),p=require('node:path'),o=require('node:os'),s=require('node:child_process');const c=process.env.CLADE_HOME||[p.join(o.homedir(),'clade'),p.join(o.homedir(),'offline','clade')].find(x=>f.existsSync(x));if(!c){console.warn('[clade] not found locally — skip bootstrap. Set CLADE_HOME or clone to ~/clade');process.exit(0)}const r=s.spawnSync('node',[p.join(c,'scripts','bootstrap-hub.mjs')],{stdio:'inherit'});process.exit(r.status||0)\"",
    "prepare": "vp config && bash scripts/restore-hooks.sh && nuxt prepare",
    "preview": "nuxt preview",
    "review:ui": "node -e \"for (const p of ['tsx', 'hono']) { try { require.resolve(p) } catch { console.error('[review:ui] Missing ' + p + '. Install with: pnpm add -D tsx hono'); process.exit(1) } }\" && pnpm exec tsx scripts/review-gui.mts",
    "setup": "bash scripts/setup.sh",
    "skills:install": "bash ./scripts/install-skills.sh",
    "skills:list": "bash ./scripts/check-skills.sh",
    "skills:update": "bash ./scripts/install-skills.sh",
    "spectra:claim": "node scripts/spectra-advanced/claim-work.mts",
    "spectra:claims": "node scripts/spectra-advanced/claims-status.mts",
    "spectra:followups": "node scripts/spectra-advanced/collect-followups.mts",
    "spectra:release": "node scripts/spectra-advanced/release-work.mts",
    "spectra:roadmap": "node scripts/spectra-advanced/roadmap-sync.mts",
    "supabase:sync": "bash ./scripts/supabase-sync.sh",
    "tag": "git tag v$(node -p \"require('./package.json').version\") && git push origin --tags",
    "test": "vp test --coverage",
    "test:e2e": "playwright test",
    "test:unit": "vp test test/unit",
    "test:watch": "vp test --watch",
    "typecheck": "nuxt typecheck",
    "update": "nuxt upgrade && pnpm skills:update && pnpm update --latest",
    "validate:starter": "node scripts/validate-starter.mjs",
    "verify:starter": "node scripts/verify-starter.mjs"
  },
  "dependencies": {
    "@nuxt/hints": "^1.1.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.6.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/supabase": "^2.0.4",
    "@onmax/nuxt-better-auth": "0.0.2-alpha.15",
    "@pinia/colada": "^1.0.0",
    "@pinia/colada-nuxt": "^0.3.2",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.46.0",
    "@supabase/supabase-js": "^2.100.0",
    "better-auth": "^1.5.6",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.16.0",
    "nuxt": "^4.4.2",
    "nuxt-charts": "^2.1.3",
    "nuxt-security": "^2.5.1",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.77.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@iconify-json/lucide": "^1.2.98",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/compiler-dom": "^3.5.31",
    "@vue/server-renderer": "^3.5.31",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^14.2.1",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.8.8",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitepress": "^1.6.4",
    "vitest": "catalog:",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.1"
}
