# Claude Code (local settings)
.claude/settings.local.json

# Third-party vendor skills installed later via `npx skills add --copy` are
# treated as local install artifacts, not starter source. Ignore them here so
# optional registry installs do not pollute the template baseline or scaffold
# output with version-drift noise.
# Skills referenced in assemble.ts are part of the starter contract and MUST
# stay tracked as real directories under `.claude/skills/`.
.claude/skills/create-evlog-*/
.claude/skills/document-writer/
.claude/skills/nuxt-content/
.claude/skills/nuxt-modules/
.claude/skills/nuxthub/
.claude/skills/review-logging-patterns/
.claude/skills/ts-library/
.claude/skills/versions.json

# TypeScript
*.tsbuildinfo

# Claude Code harness runtime state
.claude/.commit.lock
