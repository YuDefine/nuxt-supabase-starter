# ============================================
# 新專案環境變數範本
# 複製此檔案為 .env 並填入實際值
# ============================================

# ============================================
# Supabase
# ============================================
# 模式切換��local（預設，本�� Docker）或 remote（遠端 SSH）
# SUPABASE_MODE=local
# 遠端模式需額外設定：
# DEV_SSH_HOST=your-host
# DEV_PROJECT_DIR=/path/to/supabase-project

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# 給 Nuxt 使用
NUXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NUXT_PUBLIC_SUPABASE_KEY=${SUPABASE_KEY}

# ============================================
# Drizzle Query Layer（選用）
# ============================================
# Local Supabase PostgreSQL 直連預設是 54322。
# 遠端 / 雲端建議改用 Supavisor transaction mode（通常是 6543）。
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# 選填：Drizzle 特權查詢使用；未設定時會 fallback 到 DATABASE_URL。
ADMIN_DATABASE_URL=

# ============================================
# OAuth Providers（根據需要選擇）
# ============================================

# Google OAuth
# 從 Google Cloud Console 取得
# https://console.cloud.google.com/apis/credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# LINE Login
# 從 LINE Developers Console 取得
# https://developers.line.biz/console/
NUXT_OAUTH_LINE_CLIENT_ID=
NUXT_OAUTH_LINE_CLIENT_SECRET=

# GitHub OAuth
# 從 GitHub Developer Settings 取得
# https://github.com/settings/developers
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# ============================================
# Better Auth
# ============================================
# 必須至少 32 字元的隨機字串
# 可使用 openssl rand -base64 32 產生
BETTER_AUTH_SECRET=

# ============================================
# Session
# ============================================
# 必須至少 32 字元的隨機字串
# 可使用 openssl rand -base64 32 產生
NUXT_SESSION_PASSWORD=

# ============================================
# 站點配置
# ============================================
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Sentry（Production 使用）
# ============================================
SENTRY_DSN=
NUXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ============================================
# 其他（根據需要添加）
# ============================================
# NODE_ENV=development
